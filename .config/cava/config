[general]
framerate = 120
autosens = 1
sensitivity = 70

bars = 0
bar_width = 1
bar_spacing = 1

lower_cutoff_freq = 50
higher_cutoff_freq = 10000

[input]
# method = pipewire
# source = 115

method = pipewire
source = auto

[output]
method = noncurses
channels = stereo
data_format = binary
bit_format = 16bit

[color]
gradient = 1
gradient_count = 2
gradient_color_1 = '#1DE9B6'
gradient_color_2 = '#F50057'

[smoothing]
integral = 70
monstercat = 1
waves = 0
gravity = 100
ignore = 0

[eq]
# This one is tricky. You can have as much keys as you want.
# Remember to uncomment more then one key! More keys = more precision.
# Look at readme.md on github for further explanations and examples.
; 1 = 1 # bass
; 2 = 1
; 3 = 1 # midtone
; 4 = 1
; 5 = 1 # treble
