{
  "autosave": "on_focus_change",
  "icon_theme": "Zed (Default)",
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },

  "diagnostics": {
    "button": true,
    "include_warnings": true,
    "lsp_pull_diagnostics": {
      "enabled": true,
      "debounce_ms": 50
    },
    "inline": {
      "enabled": true,
      "update_debounce_ms": 150,
      "padding": 4,
      "min_column": 60,
      "max_severity": "warning"
    }
  },

  "inlay_hints": { "enabled": false },

  "auto_install_extensions": {
    "html": true,
    "dockerfile": true,
    "docker-compose": true
  },

  "base_keymap": null,
  "bottom_dock_layout": "full",
  "restore_on_startup": "last_session",

  // Vim Mode Setup
  "vim_mode": true,
  "cursor_blink": false,
  "scrollbar": { "show": "never" },
  "relative_line_numbers": false,
  "scroll_beyond_last_line": "one_page",
  "vertical_scroll_margin": 0,

  "ui_font_family": "Iosevka Nerd Font",
  "ui_font_size": 20,
  "ui_font_weight": 500,

  "buffer_line_height": { "custom": 1.35 },
  "buffer_font_size": 18,
  "buffer_font_family": "FiraCode Nerd Font",
  "buffer_font_weight": 550,
  "buffer_font_features": {
    "calt": false
  },

  "theme": {
    "mode": "system",
    "light": "VSCode Light+",
    "dark": "VSCode Light+"
  },

  "agent": { "button": false },

  "debugger": { "button": false },

  "terminal": {
    "font_size": 18,
    "font_family": "Iosevka Nerd Font",
    "font_weight": 500,
    "toolbar": {
      "breadcrumbs": false
    },
    "button": false,
    "scrollbar": { "show": "never" }
  },

  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
    "selections_menu": false,
    "agent_review": false,
    "code_actions": false
  },

  "active_pane_modifiers": {
    "border_size": 2.0,
    "inactive_opacity": 0.5
  },

  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false
  },

  "project_panel": {
    "button": false,
    "default_width": 240,
    "dock": "left",
    "entry_spacing": "standard",
    "file_icons": true,
    "folder_icons": true,
    "git_status": true,
    "indent_size": 28,
    "auto_reveal_entries": true,
    "auto_fold_dirs": true,
    "scrollbar": {
      "show": "never"
    },
    "show_diagnostics": "all",
    "indent_guides": {
      "show": "always"
    },
    "hide_root": false,
    "sticky_scroll": false
  },

  "outline_panel": {
    "button": false,
    "default_width": 300,
    "dock": "right",
    "file_icons": true,
    "folder_icons": true,
    "git_status": true,
    "indent_size": 20,
    "auto_reveal_entries": true,
    "auto_fold_dirs": true,
    "indent_guides": {
      "show": "always"
    },
    "scrollbar": {
      "show": null
    }
  },

  "tabs": {
    "file_icons": false,
    "git_status": true,
    "show_close_button": "hidden",
    "show_diagnostics": "errors"
  },

  "notification_panel": { "button": false },

  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true,
      "min_column": 100,
      "delay_ms": 500,
      "show_commit_summary": true
    },
    "hunk_style": "staged_hollow",
    "gutter_debounce": 0
  },

  "git_panel": { "button": false },

  "collaboration_panel": { "button": false },

  "title_bar": {
    "show_branch_icon": false,
    "show_sign_in": false,
    "show_user_picture": false,
    "show_menus": false,
    "show_branch_name": false,
    "show_onboarding_banner": false,
    "show_project_items": false
  },

  "features": {
    "edit_prediction_provider": "none"
  },

  "languages": {
    "JavaScript": {},
    "Make": {
      "hard_tabs": true
    },
    "Python": {
      "language_servers": ["ruff"],
      "format_on_save": "on",
      "formatter": [
        {
          "code_actions": {
            // "source.fixAll.ruff": true,
            "source.organizeImports.ruff": true
          }
        },
        {
          "language_server": {
            "name": "ruff"
          }
        }
      ]
    },
    "SQL": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "sql-formatter",
          "arguments": [
            "--language",
            "postgresql",
            "-c",
            "{ \"useTabs\": true, \"keywordCase\": \"upper\",\"functionCase\": \"upper\" }"
          ]
        }
        // "external": {
        //   "command": "pg_format",
        //   "arguments": [
        //     "-i",
        //     "-T",
        //     "--function-case",
        //     "1",
        //     "--no-space-function",
        //     "-w",
        //     "80"
        //   ]
        // }
      }
    }
  },
  "lsp": {
    "clangd": {
      "binary": {
        "path": "/usr/bin/clangd",
        "arguments": [
          "--completion-style=detailed",
          "--pretty",
          "--background-index",
          "--clang-tidy",
          "--header-insertion=never"
        ]
      }
    },
    "ruff": {
      "initialization_options": {
        "settings": {
          "lineLength": 80,
          "lint": {
            "extendSelect": ["I"]
          }
        }
      }
    }
  }
}
